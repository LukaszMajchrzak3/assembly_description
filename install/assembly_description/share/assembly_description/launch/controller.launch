<launch>

<rosparam file="$(find Assembly_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="Assembly" args="Obrót 1_position_controller Obrót 2_position_controller Obrót 3_position_controller Obrót 4_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/Assembly/joint_states"/>
</node>

</launch>