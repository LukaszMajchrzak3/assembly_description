<?xml version="1.0" ?>
<robot name="Assembly" xmlns:xacro="http://www.ros.org/wiki/xacro">
<xacro:arg name="gazebo_controllers" default="$(env HOME)/clearpath/platform/config/control.yaml" />
<xacro:include filename="$(find assembly_description)/urdf/materials.xacro" />
<xacro:include filename="$(find assembly_description)/urdf/Assembly.trans" />

<link name="chassis_link">
  <inertial>
    <origin xyz="0.0013626883253200508 8.361136291997719e-05 0.09570081394757393" rpy="0 0 0"/>
    <mass value="10.146617382602876"/>
    <inertia ixx="1.038602" iyy="1.05519" izz="1.717662" ixy="0.063507" iyz="-0.001771" ixz="-0.0094"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://assembly_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <geometry>
      <box size="0.8 0.5 0.2"/>
    </geometry>
  </collision>
</link>

<link name="Komponent390_1">
  <inertial>
    <origin xyz="1.7396688488102718e-06 0.07158422548093257 -3.680155703067456e-06" rpy="0 0 0"/>
    <mass value="3.509196383820251"/>
    <inertia ixx="0.015316" iyy="0.020222" izz="0.015316" ixy="1e-06" iyz="-1e-06" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.462407 -0.333391 0.181736" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://assembly_description/meshes/Komponent390_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.15"/>
    </geometry>
  </collision>
</link>

<link name="Komponent387_1">
  <inertial>
    <origin xyz="-2.5653229020483614e-06 -0.07158405235834175 -3.5042770395177225e-06" rpy="0 0 0"/>
    <mass value="3.50919641521173"/>
    <inertia ixx="0.015316" iyy="0.020222" izz="0.015316" ixy="1e-06" iyz="1e-06" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.461782 0.330009 0.182625" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://assembly_description/meshes/Komponent387_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.15"/>
    </geometry>
  </collision>
</link>

<link name="Komponent388_1">
  <inertial>
    <origin xyz="2.521271106392664e-06 0.07158422285030919 -3.6801312563450317e-06" rpy="0 0 0"/>
    <mass value="3.509196938643843"/>
    <inertia ixx="0.015316" iyy="0.020223" izz="0.015316" ixy="1e-06" iyz="-1e-06" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.460769 -0.333391 0.181736" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://assembly_description/meshes/Komponent388_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.15"/>
    </geometry>
  </collision>
</link>

<link name="Komponent389_1">
  <inertial>
    <origin xyz="-2.069141749050374e-06 -0.07158405236339799 -3.6457523256427926e-06" rpy="0 0 0"/>
    <mass value="3.509196414812441"/>
    <inertia ixx="0.015316" iyy="0.020222" izz="0.015316" ixy="1e-06" iyz="1e-06" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.461392 0.330009 0.180846" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://assembly_description/meshes/Komponent389_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.15"/>
    </geometry>
  </collision>
</link>

<joint name="custom_rover_base_joint" type="fixed">
  <parent link="base_link"/>
  <child link="chassis_link"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

<joint name="front_left_wheel_joint" type="continuous">
  <origin xyz="0.462407 0.333391 -0.181736" rpy="0 0 0"/>
  <parent link="chassis_link"/>
  <child link="Komponent390_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="front_right_wheel_joint" type="continuous">
  <origin xyz="0.461782 -0.330009 -0.182625" rpy="0 0 0"/>
  <parent link="chassis_link"/>
  <child link="Komponent387_1"/>
  <axis xyz="0.0 1.0 0.0"/> 
</joint>

<joint name="rear_left_wheel_joint" type="continuous">
  <origin xyz="-0.460769 0.333391 -0.181736" rpy="0 0 0"/>
  <parent link="chassis_link"/>
  <child link="Komponent388_1"/>
  <axis xyz="0.0 1.0 0.0"/> 
</joint>

<joint name="rear_right_wheel_joint" type="continuous">
  <origin xyz="-0.461392 -0.330009 -0.180846" rpy="0 0 0"/>
  <parent link="chassis_link"/>
  <child link="Komponent389_1"/>
  <axis xyz="0.0 1.0 0.0"/> 
</joint>

<ros2_control name="GazeboSystem" type="system">
  <hardware>
    <plugin>ign_ros2_control/IgnitionSystem</plugin>
  </hardware>
  <joint name="front_left_wheel_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="front_right_wheel_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="rear_left_wheel_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="rear_right_wheel_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
</ros2_control>

<gazebo>
  <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
    <parameters>$(arg gazebo_controllers)</parameters>
    <ros>
      <namespace>/a200_0000</namespace>
    </ros>
    <robot_param>robot_description</robot_param>
    <robot_param_node>robot_state_publisher</robot_param_node>
  </plugin>
</gazebo>

</robot>
